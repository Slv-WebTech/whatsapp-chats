# =============================================================================
# Lensiq — Environment Variables
# Copy to .env (local) or set in Vercel / Railway dashboard.
# Never commit .env to source control.
# =============================================================================

# --- Firebase Admin SDK (server-side only — Vercel / worker) -----------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Newlines in the private key must be escaped as \n in .env files
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Firebase Storage bucket used for signed upload URLs
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app

# --- Neon PostgreSQL (free tier at neon.tech) --------------------------------
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://lensiq_owner:xxxx@ep-xxx.us-east-1.aws.neon.tech/lensiq?sslmode=require

# --- Upstash Redis (free tier at upstash.com) --------------------------------
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxx

# --- Worker only: ioredis connection (Upstash or self-hosted) ----------------
# Use rediss:// for TLS (required by Upstash)
REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6380

# --- AI Providers ------------------------------------------------------------
# At least one key is required for AI features. The gateway tries them in order:
# OpenAI → Gemini → Ollama → local fallback
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=AIzaSy-xxxx
GEMINI_MODEL=gemini-1.5-flash

# Optional: self-hosted Ollama instance (leave blank to skip)
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.2:3b

# --- AI Gateway tuning -------------------------------------------------------
AI_GATEWAY_MAX_MESSAGES=200
AI_GATEWAY_MAX_MESSAGE_CHARS=1000
AI_GATEWAY_MAX_QUERY_CHARS=800
AI_GATEWAY_MAX_TOTAL_CHARS=32000
AI_GATEWAY_RATE_WINDOW_MS=60000
AI_GATEWAY_RATE_LIMIT=30

# --- Vite client-side env (prefix with VITE_ to expose to the browser) -------
# These point the React app at the Vercel API routes — no change needed locally
VITE_API_BASE_URL=/api

# Firebase Web SDK config (Project settings > General > Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# FCM Web Push VAPID key (Firebase console > Project settings > Cloud Messaging)
VITE_FIREBASE_VAPID_KEY=

# Optional client controls
VITE_AI_GATEWAY_ENABLED=true
VITE_AI_PROVIDER_ORDER=openai,gemini,ollama,local
