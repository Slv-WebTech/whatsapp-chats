rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function chatDoc(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }

    function isSharedRoom(chatId) {
      return chatId is string && chatId.matches('^shared-[a-z0-9]+$');
    }

    function canAccessChat(chatId) {
      return isChatMember(chatId) || (isSignedIn() && isSharedRoom(chatId));
    }

    function isChatMember(chatId) {
      return isSignedIn() && request.auth.uid in chatDoc(chatId).data.members;
    }

    function isChatOwner(chatId) {
      return isSignedIn() && chatDoc(chatId).data.ownerId == request.auth.uid;
    }

    function canModerateGroup(chatId) {
      return isAdmin() || isChatOwner(chatId);
    }

    function isOpenGroup(chatId) {
      return isSignedIn()
        && chatDoc(chatId).data.type == 'group'
        && chatDoc(chatId).data.status == 'active'
        && (
          !('joinPolicy' in chatDoc(chatId).data)
          || chatDoc(chatId).data.joinPolicy == 'group-id'
        );
    }

    function isDirectJoiningGroup() {
      return isSignedIn()
        && resource.data.type == 'group'
        && resource.data.joinPolicy == 'group-id'
        && resource.data.approvalRequired == false
        && !(request.auth.uid in resource.data.members)
        && request.auth.uid in request.resource.data.members;
    }

    function isValidMessageCreate() {
      return (
        request.resource.data.type == 'system'
        && request.resource.data.uid == 'system'
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
      ) || (
        request.resource.data.encrypted == true
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1400
        && request.resource.data.type is string
        && (
          !('pinned' in request.resource.data)
          || request.resource.data.pinned == false
        )
      );
    }

    function isMessageOwner(chatId, messageId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/chats/$(chatId)/messages/$(messageId)).data.uid == request.auth.uid;
    }

    function isValidMessageUpdate(chatId, messageId) {
      // Allow reactions, deliveredTo, readBy, hiddenFor, pinned, bookmarkedBy updates only
      let allowed = ['reactions', 'deliveredTo', 'readBy', 'hiddenFor', 'pinned', 'pinnedAt', 'bookmarkedBy'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed)
        || isAdmin()
        || canModerateGroup(chatId);
    }

    function isConfiguredAdminUid(uid) {
      return uid == 'djK91MD4FiTQIqxD392Tz8WZqnB2';
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid) && request.resource.data.role == (isConfiguredAdminUid(uid) ? 'admin' : 'user');
      allow update: if isAdmin() || (isSelf(uid) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /user_chats/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create, update: if isSelf(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if canAccessChat(chatId) || isAdmin() || isOpenGroup(chatId);
      allow create: if isSignedIn()
        && request.resource.data.members is list
        && request.resource.data.members.size() >= 1
        && request.resource.data.members.size() <= 50
        && request.auth.uid in request.resource.data.members
        && (
          request.resource.data.type != 'group'
          || (
            request.resource.data.ownerId == request.auth.uid
            && request.resource.data.createdBy == request.auth.uid
            && request.resource.data.joinPolicy == 'group-id'
          )
        );
      allow update: if canAccessChat(chatId) || isAdmin() || isDirectJoiningGroup();
      allow delete: if isAdmin() || isChatOwner(chatId);
    }

    match /chats/{chatId}/join_requests/{uid} {
      allow read: if isSelf(uid) || canModerateGroup(chatId);
      allow create: if isSignedIn()
        && uid == request.auth.uid
        && !isChatMember(chatId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.state == 'pending';
      allow update: if canModerateGroup(chatId)
        || (
          isSignedIn()
          && uid == request.auth.uid
          && !isChatMember(chatId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.state == 'pending'
        );
      allow delete: if canModerateGroup(chatId);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if canAccessChat(chatId) || isAdmin();
      allow create: if canAccessChat(chatId) && isValidMessageCreate();
      allow update: if (canAccessChat(chatId) && isValidMessageUpdate(chatId, messageId)) || isAdmin();
      allow delete: if isAdmin() || (canAccessChat(chatId) && isMessageOwner(chatId, messageId));
    }

    match /chats/{chatId}/typing/{uid} {
      allow read: if canAccessChat(chatId) || isAdmin();
      allow create, update: if (canAccessChat(chatId) && uid == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /chats/{chatId}/presence/{uid} {
      allow read: if canAccessChat(chatId) || isAdmin();
      allow create, update: if (canAccessChat(chatId) && uid == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /chats/{chatId}/{document=**} {
      allow read, write: if isAdmin();
    }

    match /admin_stats/{docId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
