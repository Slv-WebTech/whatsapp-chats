rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------------------
    // Common helpers
    // ---------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isPlatformAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.role == 'admin';
    }

    function roomDoc(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function memberDoc(roomId, uid) {
      return get(/databases/$(database)/documents/rooms/$(roomId)/members/$(uid));
    }

    function isRoomMember(roomId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/rooms/$(roomId)/members/$(request.auth.uid));
    }

    function roomOwnerId(roomId) {
      return roomDoc(roomId).data.ownerId;
    }

    function roomRole(roomId) {
      return isRoomMember(roomId)
        ? memberDoc(roomId, request.auth.uid).data.role
        : null;
    }

    function isRoomOwnerOrAdmin(roomId) {
      return isPlatformAdmin()
        || (isRoomMember(roomId) && (
          roomOwnerId(roomId) == request.auth.uid
          || roomRole(roomId) in ['owner', 'admin']
        ));
    }

    // Basic write-rate check. For docs that track lastWrite, each new write
    // must advance time and set lastWrite to request.time.
    function passesRateLimitOnUpdate() {
      return !('lastWrite' in resource.data)
        || (
          resource.data.lastWrite is timestamp
          && request.time > resource.data.lastWrite
          && ('lastWrite' in request.resource.data)
          && request.resource.data.lastWrite == request.time
        );
    }

    function onlyHasKeys(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    // ---------------------------------------------------------------------
    // 1) USERS
    // /users/{userId}
    // - Auth required
    // - Self can read/write own profile
    // - Admin can read all and write all
    // ---------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn() && (isSelf(userId) || isPlatformAdmin());

      allow create: if isSelf(userId)
        && onlyHasKeys(['username', 'usernameKey', 'email', 'role', 'createdAt', 'updatedAt', 'lastSeenAt', 'lastWrite'])
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 3
        && request.resource.data.username.size() <= 30
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.role in ['user', 'admin']
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastWrite is timestamp;

      allow update: if isSignedIn()
        && (
          isPlatformAdmin()
          || (
            isSelf(userId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'username', 'usernameKey', 'updatedAt', 'lastSeenAt', 'lastWrite'
            ])
            && request.resource.data.username is string
            && request.resource.data.username.size() >= 3
            && request.resource.data.username.size() <= 30
            && request.resource.data.updatedAt is timestamp
            && passesRateLimitOnUpdate()
          )
        );

      allow delete: if isPlatformAdmin();
    }

    // ---------------------------------------------------------------------
    // 2) PRESENCE
    // /presence/{userId}
    // - Auth required
    // - User updates own presence
    // - Others can read
    // ---------------------------------------------------------------------
    match /presence/{userId} {
      allow read: if isSignedIn();

      allow create: if isSelf(userId)
        && onlyHasKeys(['status', 'lastSeen', 'device', 'lastWrite'])
        && request.resource.data.status in ['online', 'offline', 'away']
        && request.resource.data.lastSeen is timestamp
        && request.resource.data.lastWrite is timestamp;

      allow update: if isSelf(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status', 'lastSeen', 'device', 'lastWrite'
        ])
        && request.resource.data.status in ['online', 'offline', 'away']
        && request.resource.data.lastSeen is timestamp
        && (
          !('lastWrite' in request.resource.data)
          || request.resource.data.lastWrite is timestamp
        )
        && passesRateLimitOnUpdate();

      allow delete: if isSelf(userId) || isPlatformAdmin();
    }

    // ---------------------------------------------------------------------
    // 3) ROOMS
    // /rooms/{roomId}
    // - Only members can read
    // - Only owner/admin can update
    // ---------------------------------------------------------------------
    match /rooms/{roomId} {
      allow read: if isSignedIn() && isRoomMember(roomId);

      allow create: if isSignedIn()
        && onlyHasKeys([
          'type', 'name', 'description', 'photoUrl',
          'ownerId', 'createdBy', 'members', 'memberRoles', 'memberUsernames',
          'joinPolicy', 'approvalRequired', 'status',
          'createdAt', 'updatedAt', 'lastMessageText', 'lastMessageAt',
          'lastSenderId', 'lastSenderName', 'memberMeta', 'lastWrite'
        ])
        && request.resource.data.type in ['group', 'direct']
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members is list
        && request.resource.data.members.size() >= 1
        && request.auth.uid in request.resource.data.members
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastWrite is timestamp;

      allow update: if isRoomOwnerOrAdmin(roomId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name', 'description', 'photoUrl', 'status', 'joinPolicy', 'approvalRequired',
          'members', 'memberRoles', 'memberUsernames', 'memberMeta',
          'lastMessageText', 'lastMessageAt', 'lastSenderId', 'lastSenderName',
          'updatedAt', 'lastWrite'
        ])
        && request.resource.data.updatedAt is timestamp
        && passesRateLimitOnUpdate();

      allow delete: if isRoomOwnerOrAdmin(roomId);

      // -------------------------------------------------------------------
      // 4) MEMBERS
      // /rooms/{roomId}/members/{userId}
      // - Member can read if in room
      // - Only owner/admin can add/remove/update members
      // -------------------------------------------------------------------
      match /members/{userId} {
        allow read: if isSignedIn() && isRoomMember(roomId);

        allow create: if isRoomOwnerOrAdmin(roomId)
          && request.resource.data.keys().hasOnly([
            'uid', 'username', 'role', 'joinedAt', 'lastReadAt', 'lastDeliveredAt', 'isMuted', 'lastWrite'
          ])
          && request.resource.data.uid == userId
          && request.resource.data.role in ['owner', 'admin', 'member']
          && request.resource.data.lastWrite is timestamp;

        allow update: if isRoomOwnerOrAdmin(roomId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'username', 'role', 'lastReadAt', 'lastDeliveredAt', 'isMuted', 'lastWrite'
          ])
          && request.resource.data.role in ['owner', 'admin', 'member']
          && passesRateLimitOnUpdate();

        allow delete: if isRoomOwnerOrAdmin(roomId);
      }

      // -------------------------------------------------------------------
      // 5) MESSAGES
      // /rooms/{roomId}/messages/{messageId}
      // - create/read: room member
      // - update/delete: sender only
      // - validation: size, senderId, createdAt
      // -------------------------------------------------------------------
      match /messages/{messageId} {
        function resolvedSenderId() {
          return ('senderId' in request.resource.data)
            ? request.resource.data.senderId
            : request.resource.data.uid;
        }

        function resourceSenderId() {
          return ('senderId' in resource.data)
            ? resource.data.senderId
            : resource.data.uid;
        }

        function messageHasRequiredFields() {
          return (
              ('senderId' in request.resource.data) || ('uid' in request.resource.data)
            )
            && resolvedSenderId() is string
            && resolvedSenderId() == request.auth.uid
            && request.resource.data.createdAt is timestamp;
        }

        function messageShapeIsValid() {
          return request.resource.data.keys().hasOnly([
            'senderId', 'uid', 'createdAt', 'text', 'type', 'clientId',
            'encrypted', 'cipherVersion', 'senderEnc',
            'reactions', 'deliveredTo', 'readBy', 'tags', 'moderation', 'sender',
            'lastWrite'
          ])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000
          && request.resource.data.type is string
          && request.resource.data.clientId is string
          && request.resource.data.clientId.size() > 0
          && request.resource.data.encrypted == true
          && (
            !('lastWrite' in request.resource.data)
            || request.resource.data.lastWrite is timestamp
          );
        }

        allow read: if isSignedIn() && isRoomMember(roomId);

        allow create: if isSignedIn()
          && isRoomMember(roomId)
          && messageHasRequiredFields()
          && messageShapeIsValid();

        allow update: if isSignedIn()
          && isRoomMember(roomId)
          && resourceSenderId() == request.auth.uid
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'text', 'reactions', 'readBy', 'deliveredTo', 'tags', 'moderation', 'lastWrite'
          ])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000
          && passesRateLimitOnUpdate();

        allow delete: if isSignedIn()
          && isRoomMember(roomId)
          && resourceSenderId() == request.auth.uid;
      }

      // -------------------------------------------------------------------
      // 6) INSIGHTS
      // /rooms/{roomId}/insights/{id}
      // - read: members only
      // - write: server/admin only
      // -------------------------------------------------------------------
      match /insights/{id} {
        allow read: if isSignedIn() && isRoomMember(roomId);
        allow create, update, delete: if isPlatformAdmin();
      }
    }

    // Default deny-all
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
