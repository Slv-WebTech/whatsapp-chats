{
  "name": "beyondstrings",
  "private": true,
  "version": "0.0.0",
  "description": "BeyondStrings - See Conversations Smarter. Built with React + Tailwind + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "worker": "node worker/index.js",
    "worker:dev": "node --watch worker/index.js",
    "smoke:infra": "node scripts/smoke-infra.mjs",
    "verify:prod": "npm run build && npm run smoke:infra",
    "migrate:group-approval:dry": "node scripts/normalize-group-approval.cjs --dry-run",
    "migrate:group-approval": "node scripts/normalize-group-approval.cjs"
  },
  "keywords": [
    "react",
    "tailwind",
    "beyondstrings",
    "encrypted-chat"
  ],
