    "@radix-ui/react-select": "^2.2.6",
    "@reduxjs/toolkit": "^2.11.2",
    "@upstash/redis": "^1.37.0",
    "bullmq": "^5.8.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "emoji-picker-react": "^4.12.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.0.1",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "ioredis": "^5.3.2",
